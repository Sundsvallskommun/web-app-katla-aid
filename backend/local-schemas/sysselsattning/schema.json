{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Sysselsättning och aktivitet",
  "description": "Styr krav och villkor i beslutet.",
  "required": ["sysselsattning"],
  "properties": {
    "sysselsattning": {
      "type": "string",
      "title": "Nuvarande sysselsättning",
      "oneOf": [
        { "const": "ARBETSSOKANDE", "title": "Arbetssökande" },
        { "const": "ANSTALLD", "title": "Anställd" },
        { "const": "SJUKSKRIVEN", "title": "Sjukskriven" },
        { "const": "FORALDRALEDIG", "title": "Föräldraledig" },
        { "const": "STUDERAR", "title": "Studerar" },
        { "const": "ANNAT", "title": "Annat" }
      ]
    },
    "registreradHosAf": {
      "type": "boolean",
      "title": "Är du registrerad hos Arbetsförmedlingen?",
      "description": "Obligatoriskt om du är arbetssökande."
    },
    "studerar": {
      "type": "boolean",
      "title": "Studerar du?"
    },
    "larosateSkolform": {
      "type": "string",
      "title": "Lärosäte / skolform",
      "description": "Fyll i om du studerar."
    },
    "sjukskriven": {
      "type": "boolean",
      "title": "Är du sjukskriven?"
    }
  }
}
