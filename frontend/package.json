    "ajv": "^8.20.0",
    "ajv-errors": "^3.0.0",
    "axios": "^1.15.2",
    "dayjs": "^1.11.20",
    "i18next": "^24.2.3",
    "i18next-resources-to-backend": "^1.2.1",
    "lodash": "^4.18.1",
    "lucide-react": "0.577.0",
    "next": "^16.2.4",
    "next-i18n-router": "^5.5.8",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.74.0",
    "react-i18next": "^15.7.4",
    "sass": "^1.99.0",
    "sharp": "^0.34.5",
    "yup": "^1.7.1",
    "zustand": "^5.0.12"
  },
  "resolutions": {
    "lodash.set": "npm:lodash@4.18.1",
